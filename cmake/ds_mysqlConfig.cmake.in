@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

find_dependency(PkgConfig REQUIRED)
pkg_check_modules(DSMYSQL_MYSQL REQUIRED IMPORTED_TARGET mysqlclient)

find_dependency(Boost REQUIRED)

include("${CMAKE_CURRENT_LIST_DIR}/ds_mysqlTargets.cmake")

if(TARGET ds_mysql::ds_mysql)
    target_link_libraries(ds_mysql::ds_mysql INTERFACE PkgConfig::DSMYSQL_MYSQL)
    if(TARGET Boost::headers)
        target_link_libraries(ds_mysql::ds_mysql INTERFACE Boost::headers)
    endif()
endif()