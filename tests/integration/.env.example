# Database Configuration for Integration Tests
# This file documents all environment variables needed for the integration tests.
# Copy this to .env and modify if needed (rarely required for tests).
#
# The integration tests require a running MySQL container.
# The container is automatically managed by CMake/CTest.

# MySQL Connection Settings
# DS_MYSQL_TEST_HOST: Hostname of the MySQL server
# DS_MYSQL_TEST_PORT: Port number (default MySQL port is 3306)
# DS_MYSQL_TEST_DATABASE: Database name to connect to
# DS_MYSQL_TEST_USER: Username for authentication
# DS_MYSQL_TEST_PASSWORD: Password for authentication
#
# Default values below are suitable for local development with Docker.
# The same credentials are used in docker-compose.yml to create the database.

DS_MYSQL_TEST_HOST=127.0.0.1
DS_MYSQL_TEST_PORT=3307
DS_MYSQL_TEST_DATABASE=ds_mysql_test
DS_MYSQL_TEST_USER=ds_mysql_test_user
DS_MYSQL_TEST_PASSWORD=ds_mysql_test_password
